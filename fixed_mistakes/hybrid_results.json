  "architecture": {
    "layers": [
      {
        "name": "PriceHunt fast-path",
        "latency_ms": "< 5",
        "methods": [
          "EN->RU keyboard layout fix",
          "Tire pattern normalization (205/55 R16)",
          "TYPO_MAP O(1) hash lookup",
          "rapidfuzz fuzzy match (82% threshold)",
          "pymorphy3 lemmatization",
          "SYNONYM_MAP expansion"
        ],
        "strengths": [
          "Мгновенная обработка известных опечаток",
          "Масштабируемый словарь синонимов (SYNONYM_MAP)",
          "Нулевые зависимости от тяжёлых ML-библиотек"
        ]
      },
      {
        "name": "BART algorithmic fallback",
        "latency_ms": "1–20",
        "methods": [
          "N-gram Jaccard similarity (bigram index)",
          "Phonetic index (Russian Soundex + Metaphone)",
          "Weighted Levenshtein with RU keyboard layout",
          "Digit/symbol normalization (тел3фон -> телефон)",
          "Hot-reload dictionary",
          "Capitalization preservation"
        ],
        "strengths": [
          "Ловит неизвестные опечатки без ручного словаря",
          "Звуковые ошибки (тилефон -> телефон)",
          "Перестановки букв с учётом соседних клавиш",
          "Авторасширение словаря из пользовательских запросов"
        ]
      },
      {
        "name": "BART neural (optional)",
        "latency_ms": "50–500",
        "methods": [
          "facebook/bart-base seq2seq denoising",
          "Text infilling with <mask>",
          "Sentence permutation (sept)",
          "Token deletion / document rotation"
        ],
        "strengths": [
          "Контекстная коррекция сложных фраз",
          "Zero-shot на неизвестных доменах"
        ],
        "note": "Gracefully degrades when torch/transformers unavailable"
      }
    ]
  },
