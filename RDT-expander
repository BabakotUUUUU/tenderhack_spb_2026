def _tuplify_lists(d: Dict[str, Any]) -> Dict[str, Any]:
    return {k: tuple(v) if isinstance(v, list) else v for k, v in d.items()}

def _ensure_lists(d: Dict[str, Any]) -> Dict[str, Any]:
    return {k: list(v) if isinstance(v, tuple) else v for k, v in d.items()}

def create_synonyms_from_csv(csv_file: str, output_json: str) -> None:
    synonyms: Dict[str, List[str]] = {}
    with open(csv_file, "r", encoding="utf-8") as fh:
        for row in csv.reader(fh):
            if row:
                key = row[0].strip()
                values = [v.strip() for v in row[1:] if v.strip()]
                if key and values:
                    synonyms[key] = values

    with open(output_json, "w", encoding="utf-8") as fh:
        json.dump(synonyms, fh, ensure_ascii=False, indent=2)

    logger.info("CSV → JSON: %d записей сохранено в %s.", len(synonyms), output_json)

def benchmark_expander(expander: RDTQueryExpander, queries: List[str]) -> List[Dict[str, Any]]:
    results: List[Dict[str, Any]] = []
    for query in queries:
        t_start = time.perf_counter()
        res = expander.expand(query)
        elapsed = time.perf_counter() - t_start
        results.append(
            {
                "query": query,
                "time_ms": round(elapsed * 1000, 3),
                "variants": res["variants_count"],
                "expanded": res["expanded"],
            }
        )

    if results:
        avg = sum(r["time_ms"] for r in results) / len(results)
        print(f"\n📊 Бенчмарк ({len(queries)} запросов):")
        print(f"   Среднее время: {avg:.2f} мс")
        print("   Всего вариантов:", sum(r["variants"] for r in results))

    return results


