class StopWordsManager:
    """
    Управление стоп-словами.
    Стоп-слова НЕ расширяются синонимами и по умолчанию исключаются
    из токенов запроса.
    """

    DEFAULT_STOP_WORDS: Set[str] = {
        # Русские
        "и", "в", "на", "с", "к", "у", "о", "об", "для", "без", "до",
        "по", "за", "под", "над", "из", "от", "перед", "при", "через",
        "а", "но", "или", "либо", "то", "это", "так", "вот", "же",
        "бы", "да", "нет", "не", "ни", "что", "как", "также", "где",
        "куда", "откуда", "когда", "почему", "зачем", "какой", "какая",
        "какое", "какие", "чей", "чья", "чьё", "чьи", "который",
        "весь", "вся", "всё", "все", "самый", "каждый", "любой",
        "я", "мы", "ты", "вы", "он", "она", "они", "оно",
        "мой", "твой", "наш", "ваш", "его", "её", "их",
        "себя", "мне", "меня", "тебе", "тебя", "ещё", "уже",
        "был", "была", "было", "были", "будет", "будут", "есть",
        "можно", "нужно", "надо", "должен", "очень", "более", "менее",
        # Английские
        "the", "a", "an", "and", "or", "but", "in", "on", "at",
        "to", "for", "of", "with", "from", "by", "is", "are", "was",
        "were", "be", "been", "being", "have", "has", "had", "do",
        "does", "did", "will", "would", "could", "should", "may",
        "might", "can", "shall", "you", "i", "he", "she", "it",
        "we", "they", "me", "him", "her", "us", "them", "my", "your",
        "his", "its", "our", "their", "this", "that", "these", "those",
        "where", "when", "why", "how", "which", "who", "whom", "whose",
        "all", "any", "each", "every", "some", "no", "not", "very",
        "just", "only", "also", "too", "here", "there", "now", "then",
    }

    def __init__(self, custom_stop_words: Optional[Set[str]] = None) -> None:
        self.stop_words: Set[str] = self.DEFAULT_STOP_WORDS.copy()
        if custom_stop_words:
            self.stop_words.update(w.lower() for w in custom_stop_words)

    def is_stop_word(self, word: str) -> bool:
        return word.lower() in self.stop_words

    def add_stop_word(self, word: str) -> None:
        w = word.lower()
        if w not in self.stop_words:
            self.stop_words.add(w)
            logger.info("Добавлено стоп-слово: '%s'", word)

    def remove_stop_word(self, word: str) -> None:
        self.stop_words.discard(word.lower())
        logger.info("Удалено стоп-слово: '%s'", word)

    def filter(self, words: Iterable[str]) -> List[str]:
        return [w for w in words if not self.is_stop_word(w)]


