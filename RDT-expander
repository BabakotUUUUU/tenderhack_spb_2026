    print("\n" + "=" * 70)
    print("🔍  ТЕСТИРОВАНИЕ РАСШИРЕНИЯ")
    print("=" * 70)

    for query in test_queries:
        print(f"\n📝 Запрос:  {query}")
        result = expander.expand(query, return_format="all")
        print(f"   ⏱️  {result['processing_time'] * 1000:.2f} мс")
        print(f"   🔬 Токены: {result['tokens']}")
        print(f"   🎯 OR/AND:  {result['or_query']}")
        if result["variants"]:
            shown = min(5, len(result["variants"]))
            print(f"   📋 Варианты ({shown}/{result['variants_count']}):")
            for v in result["variants"][:shown]:
                print(f"      • {v}")

    print("\n" + "=" * 70)
    print("📤  ЭКСПОРТ")
    print("=" * 70)

    q = "купить недорогой ноутбук"
    es = expander.export_for_elasticsearch(q)
    print("\n🔷 Elasticsearch:")
    print(json.dumps(es, ensure_ascii=False, indent=2))

    sql = expander.export_for_sql(q, "title")
    print(f"\n🔷 SQL (первые 200 символов):\n   {sql[:200]}...")

    plain = expander.export_for_plain(q)
    print(f"\n🔷 Plain (первые 5):")
    for p in plain[:5]:
        print(f"   • {p}")

    print("\n" + "=" * 70)
    print("➕  ДИНАМИЧЕСКОЕ ДОБАВЛЕНИЕ")
    print("=" * 70)

    expander.add_synonym("ноутбук", "ультрабук", weight=0.85)
    expander.add_synonym("ноутбук", "нетбук", weight=0.70)
    r = expander.expand("ноутбук", return_format="variants")
    print("Варианты для «ноутбук» после добавления:")
    for v in r["variants"]:
        print(f"   • {v}")

    print("\n" + "=" * 70)
    print("➖  УДАЛЕНИЕ СИНОНИМА")
    print("=" * 70)
    expander.remove_synonym("ноутбук", "нетбук")
    r2 = expander.expand("ноутбук", return_format="variants")
    print("После удаления «нетбук»:")
    for v in r2["variants"]:
        print(f"   • {v}")

    print("\n" + "=" * 70)
    print("📊  ИТОГОВАЯ СТАТИСТИКА")
    print("=" * 70)
    fs = expander.get_stats()
    print(f"   Обработано запросов:  {fs['total_expansions']}")
    print(f"   Топ-5 терминов:       {fs['most_used'][:5]}")
    if fs["cache_info"]:
        ci = fs["cache_info"]
        print(f"   Кэш:  hits={ci['hits']}, misses={ci['misses']}, "
              f"size={ci['currsize']}/{ci['maxsize']}")

    print("\n" + "=" * 70)
    print("⚡  БЕНЧМАРК")
    print("=" * 70)
    benchmark_expander(
        expander,
        ["купить ноутбук", "apple смартфон", "быстрый ремонт мск"],
    )

    print("\n✅  Готово!\n")
    return expander

