class RDTQueryExpander:
    def __init__(
        self,
        synonyms_file: Optional[str] = None,
        enable_cache: bool = True,
        max_combinations: int = 100,
        auto_detect_phrases: bool = True,
        bidirectional: bool = True,
        custom_stop_words: Optional[Set[str]] = None,
    ) -> None:
        self.synonyms: Dict[str, List[SynonymWeight]] = {}
        self._phrase_set: Set[str] = set()

        self.enable_cache = enable_cache
        self.max_combinations = max_combinations
        self.auto_detect_phrases = auto_detect_phrases
        self.bidirectional = bidirectional

        self.stop_words_manager = StopWordsManager(custom_stop_words)

        self.usage_stats: Counter = Counter()
        self.expansion_history: List[Dict[str, Any]] = []

        if synonyms_file:
            self.load_synonyms(synonyms_file)
        else:
            self._load_default_synonyms()

        logger.info(
            "RDTQueryExpander готов. Ключей: %d, фраз: %d, "
            "bidirectional: %s, кэш: %s.",
            len(self.synonyms),
            len(self._phrase_set),
            self.bidirectional,
            "вкл" if self.enable_cache else "выкл",
        )

    def _load_default_synonyms(self) -> None:
        defaults: Dict[str, List[Tuple[str, float]]] = {
            "ноутбук": [("лэптоп", 0.90), ("портативный компьютер", 0.80), ("ноут", 0.60)],
            "apple": [("macbook", 0.95), ("mac", 0.85), ("яблочный", 0.50)],
            "купить": [("приобрести", 0.90), ("заказать", 0.80), ("оформить", 0.50)],
            "недорогой": [("бюджетный", 0.90), ("дешёвый", 0.70), ("доступный", 0.80)],
            "искусственный интеллект": [("нейронные сети", 0.80), ("машинное обучение", 0.85), ("AI", 0.90)],
            "смартфон": [("мобильный телефон", 0.95), ("телефон", 0.70), ("гаджет", 0.60)],
            "санкт-петербург": [("спб", 0.95), ("питер", 0.90), ("ленинград", 0.40)],
            "быстрый": [("скорый", 0.80), ("оперативный", 0.75), ("проворный", 0.50)],
            "хороший": [("отличный", 0.85), ("превосходный", 0.70), ("качественный", 0.80)],
            "ремонт": [("починка", 0.90), ("восстановление", 0.70), ("сервис", 0.60)],
            "москва": [("мск", 0.95), ("столица", 0.50)],
        }
        for key, syns in defaults.items():
            self.synonyms[key] = [SynonymWeight(w, wt) for w, wt in syns]
            if " " in key:
                self._phrase_set.add(key)

        if self.bidirectional:
            self._build_reverse_index()

    def load_synonyms(self, file_path: str) -> None:
        path = Path(file_path)
        if not path.exists():
            raise FileNotFoundError(f"Файл словаря не найден: {file_path}")

        with open(path, "r", encoding="utf-8") as fh:
            data = json.load(fh)

        for key, value in data.items():
            key_norm = self._normalize_word(key)
            if isinstance(value, list):
                if all(isinstance(v, str) for v in value):
                    self.synonyms[key_norm] = [SynonymWeight(v, 1.0) for v in value]
                elif all(isinstance(v, dict) for v in value):
                    self.synonyms[key_norm] = [
                        SynonymWeight(v["word"], v.get("weight", 1.0)) for v in value
                    ]
            elif isinstance(value, dict):
                self.synonyms[key_norm] = [SynonymWeight(w, wt) for w, wt in value.items()]
            else:
                logger.warning("Пропущен ключ '%s' — неизвестный формат.", key)
                continue

            if " " in key_norm:
                self._phrase_set.add(key_norm)

        if self.bidirectional:
            self._build_reverse_index()

        self._clear_cache()
        logger.info("Загружено %d ключей из %s.", len(self.synonyms), file_path)

    def save_synonyms(self, file_path: str) -> None:
        output: Dict[str, List[Dict[str, Any]]] = {}
        for key, weights in self.synonyms.items():
            output[key] = [{"word": sw.word, "weight": sw.weight} for sw in weights]
        with open(file_path, "w", encoding="utf-8") as fh:
            json.dump(output, fh, ensure_ascii=False, indent=2)
        logger.info("Словарь сохранён: %s (%d ключей).", file_path, len(output))

    def _build_reverse_index(self) -> None:
        additions: Dict[str, List[SynonymWeight]] = {}
        for base, syn_list in self.synonyms.items():
            for sw in syn_list:
                rev_key = self._normalize_word(sw.word)
                
                existing = False
                if rev_key in self.synonyms:
                    if any(s.word == base for s in self.synonyms[rev_key]):
                        existing = True
                
                if rev_key in additions:
                    if any(s.word == base for s in additions[rev_key]):
                        existing = True
                        
                if not existing:
                    additions.setdefault(rev_key, []).append(SynonymWeight(base, sw.weight))

        for key, syns in additions.items():
            if key in self.synonyms:
                self.synonyms[key].extend(syns)
            else:
                self.synonyms[key] = syns
            if " " in key:
                self._phrase_set.add(key)

        total_added = sum(len(v) for v in additions.values())
        if total_added > 0:
            logger.info("Добавлено %d обратных связей (bidirectional).", total_added)

    def add_synonym(self, word: str, synonym: str, weight: float = 1.0) -> None:
        word_norm = self._normalize_word(word)
        self.synonyms.setdefault(word_norm, [])

        for sw in self.synonyms[word_norm]:
            if sw.word == synonym:
                sw.weight = weight
                logger.info("Обновлён вес '%s' → '%s': %.2f", word_norm, synonym, weight)
                self._clear_cache()
                return

        self.synonyms[word_norm].append(SynonymWeight(synonym, weight))
        if " " in word_norm:
            self._phrase_set.add(word_norm)

        if self.bidirectional:
            rev_key = self._normalize_word(synonym)
            self.synonyms.setdefault(rev_key, [])
            if not any(sw.word == word_norm for sw in self.synonyms[rev_key]):
                self.synonyms[rev_key].append(SynonymWeight(word_norm, weight))
                if " " in rev_key:
                    self._phrase_set.add(rev_key)

        self._clear_cache()
        logger.info("Добавлен синоним '%s' (вес:%.2f) для '%s'.", synonym, weight, word_norm)

    def remove_synonym(self, word: str, synonym: str) -> bool:
        word_norm = self._normalize_word(word)
        if word_norm not in self.synonyms:
            logger.warning("Ключ '%s' не найден в словаре.", word_norm)
            return False

        before = len(self.synonyms[word_norm])
        self.synonyms[word_norm] = [sw for sw in self.synonyms[word_norm] if sw.word != synonym]
        after = len(self.synonyms[word_norm])

        if after == 0:
            del self.synonyms[word_norm]
            self._phrase_set.discard(word_norm)

        if after < before:
            self._clear_cache()
            logger.info("Удалён синоним '%s' для '%s'.", synonym, word_norm)
            return True

        logger.warning("Синоним '%s' для '%s' не найден.", synonym, word_norm)
        return False

    def _normalize_word(self, word: str) -> str:
        w = word.strip()
        if not w:
            return w
        w_lower = w.lower()
        if MORPH_AVAILABLE and len(w_lower) > 1 and w_lower.replace("-", "").isalpha():
            try:
                parsed = morph.parse(w_lower)[0]
                return parsed.normal_form
            except Exception:
                return w_lower
        return w_lower

    def _detect_phrases(self, query: str) -> Tuple[str, List[str]]:
        if not self.auto_detect_phrases or not self._phrase_set:
            return query, []

        detected: List[str] = []
        query_lower = query.lower()
        phrases_sorted = sorted(self._phrase_set, key=len, reverse=True)

        replacements: List[Tuple[int, int, str]] = []

        for phrase in phrases_sorted:
            start = 0
            while True:
                idx = query_lower.find(phrase, start)
                if idx == -1:
                    break
                left_ok = idx == 0 or not query_lower[idx - 1].isalnum()
                right_ok = (
                    idx + len(phrase) == len(query_lower)
                    or not query_lower[idx + len(phrase)].isalnum()
                )
                if left_ok and right_ok:
                    overlaps = any(
                        idx < e and idx + len(phrase) > s
                        for s, e, _ in replacements
                    )
                    if not overlaps:
                        replacements.append((idx, idx + len(phrase), phrase))
                        detected.append(phrase)
                start = idx + 1

        result_chars = list(query)
        for start, end, phrase in sorted(
            replacements, key=lambda x: x[0], reverse=True
        ):
            result_chars[start:end] = [f'"{phrase}"']

        return "".join(result_chars), detected

    def _parse_tokens(self, query: str) -> List[Tuple[str, str]]:
        tokens: List[Tuple[str, str]] = []

        query_with_quotes, _ = self._detect_phrases(query)

        # Токенизируем, сохраняя порядок
        # Ищем фразы в кавычках ИЛИ обычные слова (допускаем слова с дефисами)
        pattern = re.compile(r'"([^"]+)"|([а-яёa-z0-9]+(?:-[а-яёa-z0-9]+)*)', re.IGNORECASE)
        for match in pattern.finditer(query_with_quotes):
            phrase = match.group(1)
            word = match.group(2)

            if phrase:
                p = phrase.lower().strip()
                if p:
                    tokens.append(("phrase", p))
            elif word:
                if not self.stop_words_manager.is_stop_word(word):
                    norm = self._normalize_word(word)
                    if norm:
                        tokens.append(("word", norm))

        return tokens

    def _get_synonyms_with_weights(self, term: str) -> List[Tuple[str, float]]:
        seen: Dict[str, float] = {term: 1.0}

        if term in self.synonyms:
            for sw in self.synonyms[term]:
                seen[sw.word] = max(seen.get(sw.word, 0.0), sw.weight)

        term_norm = self._normalize_word(term)
        if term_norm != term and term_norm in self.synonyms:
            for sw in self.synonyms[term_norm]:
                seen[sw.word] = max(seen.get(sw.word, 0.0), sw.weight)

        return sorted(seen.items(), key=lambda x: x[1], reverse=True)

    def _expand_impl(self, query: str, return_format: str) -> Dict[str, Any]:
        t0 = datetime.now()
        logger.info("Расширение: %s", query)

        tokens = self._parse_tokens(query)

        if not tokens:
            return {
                "original": query,
                "expanded": False,
                "or_query": query,
                "variants": [query],
                "variants_count": 1,
                "tokens": [],
                "processing_time": (datetime.now() - t0).total_seconds(),
            }

        groups: List[List[str]] = []
        for tok_type, tok_value in tokens:
            syns = self._get_synonyms_with_weights(tok_value)
            group: List[str] = []
            for word, _ in syns:
                if tok_type == "phrase" and " " in word:
                    group.append(f'"{word}"')
                else:
                    group.append(word)
            groups.append(group)

        for g in groups:
            for term in g:
                self.usage_stats[term] += 1

        or_parts = ["(" + " OR ".join(g) + ")" for g in groups]
        or_query = " AND ".join(or_parts)

        total = 1
        for g in groups:
            total *= len(g)
        variants_count = min(total, self.max_combinations)

        variants: List[str] = []
        if return_format in ("variants", "all") and groups:
            for combo in islice(product(*groups), self.max_combinations):
                variants.append(" ".join(combo))

        self.expansion_history.append(
            {
                "original": query,
                "or_query": or_query,
                "tokens_count": len(tokens),
                "variants_count": variants_count,
                "timestamp": t0.isoformat(),
            }
        )

        return {
            "original": query,
            "expanded": True,
            "tokens": tokens,
            "or_query": or_query,
            "variants": variants[: self.max_combinations],
            "variants_count": variants_count,
            "processing_time": (datetime.now() - t0).total_seconds(),
        }

    def expand(self, query: str, return_format: str = "or_query") -> Dict[str, Any]:
        result = (
            self._expand_cached(query, return_format)
            if self.enable_cache
            else self._expand_impl(query, return_format)
        )
        return _ensure_lists(result)

    @lru_cache(maxsize=1000)
    def _expand_cached(self, query: str, return_format: str) -> Dict[str, Any]:
        raw = self._expand_impl(query, return_format)
        return _tuplify_lists(raw)

    def _clear_cache(self) -> None:
        if self.enable_cache:
            self._expand_cached.cache_clear()
            logger.info("Кэш очищен.")

    def get_stats(self) -> Dict[str, Any]:
        cache_info = None
        if self.enable_cache:
            ci = self._expand_cached.cache_info()
            cache_info = {
                "hits": ci.hits,
                "misses": ci.misses,
                "currsize": ci.currsize,
                "maxsize": ci.maxsize,
            }

        return {
            "total_synonyms": sum(len(v) for v in self.synonyms.values()),
            "unique_keys": len(self.synonyms),
            "phrase_keys": len(self._phrase_set),
            "most_used": self.usage_stats.most_common(10),
            "total_expansions": len(self.expansion_history),
            "cache_info": cache_info,
            "morphology_enabled": MORPH_AVAILABLE,
            "auto_detect_phrases": self.auto_detect_phrases,
            "bidirectional": self.bidirectional,
            "max_combinations": self.max_combinations,
        }

    def export_for_elasticsearch(self, query: str) -> Dict[str, Any]:
        expanded = self.expand(query, return_format="or_query")
        if not expanded["expanded"]:
            return {"query": {"match": {"content": query}}}
        return {
            "query": {
                "query_string": {
                    "query": expanded["or_query"],
                    "default_operator": "AND",
                }
            }
        }

    def export_for_sql(self, query: str, column: str = "content", limit: int = 10) -> str:
        expanded = self.expand(query, return_format="variants")
        variants = expanded.get("variants", [])
        if not variants:
            return f"{column} LIKE '%{query}%'"
        conditions = [f"{column} LIKE '%{v}%'" for v in variants[:limit]]
        return " OR ".join(conditions)

    def export_for_plain(self, query: str) -> List[str]:
        expanded = self.expand(query, return_format="variants")
        return expanded.get("variants", [])


